# Copy to .env.local and fill in real values. .env.local is gitignored.

# ── Database (required for the contact form to persist inquiries) ──────────────
# Any Postgres connection string. Neon (serverless) is recommended for Vercel.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Public site URL (metadata, sitemap, Open Graph) ───────────────────────────
NEXT_PUBLIC_SITE_URL="https://seanmuchenje.com"

# ── Email delivery (optional) ─────────────────────────────────────────────────
# When RESEND_API_KEY is set, new inquiries are also emailed. Without it, the
# contact form still works and persists submissions to the database.
RESEND_API_KEY=""
CONTACT_TO_EMAIL="seanshairah@gmail.com"

# ── Authentication (NEXT PHASE — not yet wired up) ────────────────────────────
# Reserved for the upcoming admin / auth phase (e.g. an inquiries dashboard).
# NextAuth / Auth.js v5 reads AUTH_SECRET; v4 reads NEXTAUTH_SECRET + NEXTAUTH_URL.
# Generate a secret with:  openssl rand -base64 32
# AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# NEXTAUTH_URL="http://localhost:3000"
# Example OAuth provider (fill in when a provider is chosen):
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
